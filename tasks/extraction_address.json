{
  "raw_input": "Extract a postal address into structured JSON with these fields: street (string, including house number), city (string), region (string, state/province/Land — null if truly absent), postal_code (string, preserving format), country (string, full name not ISO code).\n\nAddress: '221B Baker Street, Marylebone, London NW1 6XE, United Kingdom'\n\nReturn only the JSON object.",
  "task_class": "verifiable",
  "task_type": "extraction",
  "deliverable_type": "json",
  "success_criteria": [
    "valid JSON matching schema",
    "street contains '221B Baker Street'",
    "city = 'London'",
    "region = 'Marylebone' or 'England' (either is acceptable)",
    "postal_code = 'NW1 6XE' (preserve the space)",
    "country = 'United Kingdom'"
  ],
  "constraints": [
    "single JSON object",
    "no markdown fences, no prose"
  ],
  "risk_level": "low",
  "verifier": {
    "kind": "json_schema",
    "inline": {
      "schema": {
        "type": "object",
        "required": ["street", "city", "region", "postal_code", "country"],
        "properties": {
          "street": {"type": "string"},
          "city": {"type": "string"},
          "region": {"type": "string"},
          "postal_code": {"type": "string"},
          "country": {"type": "string"}
        }
      }
    }
  }
}
